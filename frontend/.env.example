# ============================================
# ArtDrive Frontend - Environment Variables
# Vercel: Set these in Project Settings > Environment Variables
# ============================================

# Backend API URL (your Railway backend URL)
REACT_APP_API_URL=https://your-backend.railway.app/api

# Socket.IO URL (same as backend, without /api)
REACT_APP_SOCKET_URL=https://your-backend.railway.app

# Auth Mode (PROD for production)
REACT_APP_AUTH_MODE=PROD
