# ============================================
# ArtDrive Backend - Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Server
PORT=5000
NODE_ENV=production

# MongoDB (use MongoDB Atlas for production)
# Railway: Set this in the Railway dashboard under Variables
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/artdrive?retryWrites=true&w=majority

# JWT - CHANGE THIS to a random secure string in production!
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECURE_STRING
JWT_EXPIRE=7d

# Auth Mode: PROD for production (full JWT auth)
AUTH_MODE=PROD

# Frontend URL (for CORS - set to your Vercel domain)
FRONTEND_URL=https://your-app.vercel.app

# Admin seed account (created on first startup)
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=Qwerty1234
