# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/artdrive

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Auth Mode: DEV or PROD
# DEV mode allows frontend localStorage authentication (for testing)
# PROD mode requires full backend JWT authentication
AUTH_MODE=DEV

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# AWS S3 Configuration (optional - for production image storage)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_BUCKET_NAME=artdrive-uploads
# AWS_REGION=us-east-1

